// Mock environment variables first, before any imports
const originalEnv = process.env;
process.env = {
  ...originalEnv,
  NEXT_PUBLIC_SUPABASE_URL: 'https://test.supabase.co',
  NEXT_PUBLIC_SUPABASE_ANON_KEY: 'test-key'
};

// Mock Supabase
jest.mock('@supabase/supabase-js', () => ({
  createClient: jest.fn(() => ({
    from: jest.fn(() => ({
      insert: jest.fn(() => ({
        select: jest.fn(() => ({
          single: jest.fn()
        }))
      })),
      select: jest.fn(() => ({
        eq: jest.fn(() => ({
          single: jest.fn()
        })),
        count: jest.fn()
      })),
      update: jest.fn(() => ({
        eq: jest.fn()
      }))
    }))
  }))
}));

import { DatabaseService, User } from '../database';

afterAll(() => {
  process.env = originalEnv;
});

describe('DatabaseService', () => {
  const mockUser: Omit<User, 'id' | 'created_at' | 'updated_at'> = {
    full_name: 'Test User',
    email: 'test@example.com',
    password_hash: 'hashed_password_123',
    email_verified: false
  };

  const mockUserResponse: User = {
    id: '123',
    ...mockUser,
    created_at: '2024-01-01T00:00:00Z',
    updated_at: '2024-01-01T00:00:00Z'
  };

  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('createUser', () => {
    it('should create a user successfully', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().insert().select().single.mockResolvedValue({
        data: mockUserResponse,
        error: null
      });

      const result = await DatabaseService.createUser(mockUser);

      expect(result.success).toBe(true);
      expect(result.user).toEqual(mockUserResponse);
      expect(result.error).toBeUndefined();
      expect(mockSupabase.from).toHaveBeenCalledWith('users');
    });

    it('should handle duplicate email error', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().insert().select().single.mockResolvedValue({
        data: null,
        error: {
          code: '23505',
          message: 'duplicate key value violates unique constraint "users_email_key"'
        }
      });

      const result = await DatabaseService.createUser(mockUser);

      expect(result.success).toBe(false);
      expect(result.error).toBe('Email đã được sử dụng. Vui lòng sử dụng email khác.');
      expect(result.user).toBeUndefined();
    });

    it('should handle general database errors', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().insert().select().single.mockResolvedValue({
        data: null,
        error: {
          code: 'UNKNOWN',
          message: 'Database connection failed'
        }
      });

      const result = await DatabaseService.createUser(mockUser);

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi tạo tài khoản. Vui lòng thử lại.');
      expect(result.user).toBeUndefined();
    });

    it('should handle unexpected errors', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().insert().select().single.mockRejectedValue(
        new Error('Network error')
      );

      const result = await DatabaseService.createUser(mockUser);

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi tạo tài khoản. Vui lòng thử lại.');
      expect(result.user).toBeUndefined();
    });
  });

  describe('getUserByEmail', () => {
    it('should find a user by email successfully', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select().eq().single.mockResolvedValue({
        data: mockUserResponse,
        error: null
      });

      const result = await DatabaseService.getUserByEmail('test@example.com');

      expect(result.success).toBe(true);
      expect(result.user).toEqual(mockUserResponse);
      expect(result.error).toBeUndefined();
      expect(mockSupabase.from).toHaveBeenCalledWith('users');
    });

    it('should handle user not found', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select().eq().single.mockResolvedValue({
        data: null,
        error: {
          code: 'PGRST116',
          message: 'No rows found'
        }
      });

      const result = await DatabaseService.getUserByEmail('notfound@example.com');

      expect(result.success).toBe(false);
      expect(result.error).toBe('Không tìm thấy tài khoản với email này.');
      expect(result.user).toBeUndefined();
    });

    it('should handle database errors', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select().eq().single.mockResolvedValue({
        data: null,
        error: {
          code: 'UNKNOWN',
          message: 'Database error'
        }
      });

      const result = await DatabaseService.getUserByEmail('test@example.com');

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi tìm kiếm tài khoản.');
      expect(result.user).toBeUndefined();
    });

    it('should handle unexpected errors', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select().eq().single.mockRejectedValue(
        new Error('Network error')
      );

      const result = await DatabaseService.getUserByEmail('test@example.com');

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi tìm kiếm tài khoản.');
      expect(result.user).toBeUndefined();
    });
  });

  describe('verifyUserEmail', () => {
    it('should verify user email successfully', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().update().eq.mockResolvedValue({
        error: null
      });

      const result = await DatabaseService.verifyUserEmail('test@example.com');

      expect(result.success).toBe(true);
      expect(result.error).toBeUndefined();
      expect(mockSupabase.from).toHaveBeenCalledWith('users');
    });

    it('should handle database errors during email verification', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().update().eq.mockResolvedValue({
        error: {
          code: 'UNKNOWN',
          message: 'Database error'
        }
      });

      const result = await DatabaseService.verifyUserEmail('test@example.com');

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi xác thực email.');
    });

    it('should handle unexpected errors during email verification', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().update().eq.mockRejectedValue(
        new Error('Network error')
      );

      const result = await DatabaseService.verifyUserEmail('test@example.com');

      expect(result.success).toBe(false);
      expect(result.error).toBe('Có lỗi xảy ra khi xác thực email.');
    });
  });

  describe('healthCheck', () => {
    it('should pass health check successfully', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select.mockResolvedValue({
        error: null
      });

      const result = await DatabaseService.healthCheck();

      expect(result.success).toBe(true);
      expect(result.error).toBeUndefined();
      expect(mockSupabase.from).toHaveBeenCalledWith('users');
    });

    it('should handle health check database errors', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select.mockResolvedValue({
        error: {
          code: 'CONNECTION_ERROR',
          message: 'Cannot connect to database'
        }
      });

      const result = await DatabaseService.healthCheck();

      expect(result.success).toBe(false);
      expect(result.error).toBe('Database connection failed');
    });

    it('should handle unexpected errors during health check', async () => {
      const { supabase } = require('@supabase/supabase-js');
      const mockSupabase = supabase();
      
      mockSupabase.from().select.mockRejectedValue(
        new Error('Network error')
      );

      const result = await DatabaseService.healthCheck();

      expect(result.success).toBe(false);
      expect(result.error).toBe('Database connection error');
    });
  });

  describe('Input validation', () => {
    it('should handle empty email in getUserByEmail', async () => {
      const result = await DatabaseService.getUserByEmail('');
      
      // The function should still attempt the query, but Supabase will handle the empty string
      expect(result.success).toBe(false);
    });

    it('should handle empty email in verifyUserEmail', async () => {
      const result = await DatabaseService.verifyUserEmail('');
      
      // The function should still attempt the query, but Supabase will handle the empty string
      expect(result.success).toBe(false);
    });
  });
}); 