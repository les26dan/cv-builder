#!/bin/bash

# OkBuddy Server Health Check
# Quick status and health verification

set -e

# Color codes
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

PID_FILE="server.pid"
PORT=3000

echo -e "${CYAN}🔍 OkBuddy Server Health Check${NC}"
echo "================================"

# Check PID file
if [ ! -f "$PID_FILE" ]; then
    echo -e "${RED}❌ Server not running (no PID file)${NC}"
    echo -e "${YELLOW}💡 Start with: ./start-server${NC}"
    exit 1
fi

PID=$(cat "$PID_FILE")

# Check if process is running
if ! kill -0 "$PID" 2>/dev/null; then
    echo -e "${RED}❌ Server process not running (PID: $PID)${NC}"
    rm -f "$PID_FILE"
    echo -e "${YELLOW}💡 Start with: ./start-server${NC}"
    exit 1
fi

# Check HTTP response
if curl -s "http://localhost:$PORT" >/dev/null 2>&1; then
    echo -e "${GREEN}✅ Server is healthy and responding${NC}"
    echo -e "${CYAN}📊 URL: http://localhost:$PORT${NC}"
    echo -e "${CYAN}🆔 PID: $PID${NC}"
    echo -e "${CYAN}📋 Logs: tail -f server-persistent.log${NC}"
    
    # Show latest log entries
    echo ""
    echo -e "${CYAN}📋 Latest logs:${NC}"
    tail -3 server-persistent.log 2>/dev/null || echo "No logs available"
else
    echo -e "${RED}❌ Server not responding on port $PORT${NC}"
    echo -e "${YELLOW}💡 Check logs: tail -f server-persistent.log${NC}"
    exit 1
fi 