# ====================
# OKBUDDY PRODUCTION ENVIRONMENT CONFIGURATION
# ====================

# ====================
# SUPABASE DATABASE
# ====================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ====================
# OAUTH PROVIDERS
# ====================

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# LinkedIn OAuth  
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# ====================
# APPLICATION SECURITY
# ====================

# JWT Secret for session management (generate with: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-key-here"

# CAPTCHA (if using reCAPTCHA)
RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# ====================
# APPLICATION CONFIGURATION
# ====================

# Environment
NODE_ENV="production"

# Application URL
NEXT_PUBLIC_APP_URL="https://www.okbuddy.io"

# API Base URL (usually same as app URL)
NEXT_PUBLIC_API_URL="https://www.okbuddy.io/api"

# OAuth Redirect URIs (production)
GOOGLE_REDIRECT_URI="https://www.okbuddy.io/api/auth/google/callback"
LINKEDIN_REDIRECT_URI="https://www.okbuddy.io/api/auth/linkedin/callback"

# ====================
# FILE UPLOAD CONFIGURATION
# ====================

# Maximum file size in bytes (10MB default)
MAX_FILE_SIZE="10485760"

# Allowed file types
ALLOWED_FILE_TYPES="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword"

# ====================
# RATE LIMITING
# ====================

# Requests per minute per IP
RATE_LIMIT_RPM="60"

# Requests per hour per user
RATE_LIMIT_RPH="1000"

# ====================
# MONITORING & ANALYTICS
# ====================

# Error tracking (if using Sentry)
SENTRY_DSN="your-sentry-dsn"

# Analytics (if using Google Analytics)
GOOGLE_ANALYTICS_ID="GA-XXXXX-X"

# ====================
# DEVELOPMENT ONLY
# ====================

# Enable debug logging (set to "false" in production)
DEBUG="false"

# Disable telemetry
NEXT_TELEMETRY_DISABLED="1"

# ====================
# DEPLOYMENT CONFIGURATION
# ====================

# Build configuration
ANALYZE="false"

# ====================
# SETUP INSTRUCTIONS
# ====================

# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env.local to version control
# 4. For production, set these as environment variables in your hosting platform

# ====================
# SECURITY NOTES
# ====================

# - Never expose service role keys in client-side code
# - Rotate secrets regularly (every 90 days)
# - Use different credentials for development/staging/production
# - Monitor for unauthorized access in Supabase dashboard
# - Enable 2FA on all service accounts 