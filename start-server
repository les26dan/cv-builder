#!/bin/bash

# OkBuddy Persistent Background Server
# Enhanced with permanent webpack error prevention
# Updated January 2025 - PERMANENT FIX VERSION

set -e

# Color codes for better output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
PORT=3000
PID_FILE="server.pid"
LOG_FILE="server-persistent.log"
MAX_RETRIES=3
HEALTH_CHECK_TIMEOUT=30

# Parse command line arguments
FORCE_CLEAN=false
if [ "$1" = "--clean" ] || [ "$1" = "-c" ]; then
    FORCE_CLEAN=true
    echo -e "${YELLOW}🧹 Aggressive cache cleaning requested${NC}"
elif [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo -e "${BLUE}OkBuddy Server - Usage:${NC}"
    echo -e "${CYAN}  ./start-server          ${NC}Start server with smart cache management"
    echo -e "${CYAN}  ./start-server --clean  ${NC}Force aggressive cache clearing before start"
    echo -e "${CYAN}  ./start-server -c       ${NC}Same as --clean (short form)"
    echo -e "${CYAN}  ./start-server --help   ${NC}Show this help message"
    echo ""
    echo -e "${YELLOW}Cache Cleaning Behavior:${NC}"
    echo -e "  ${GREEN}Smart (default):${NC} Only cleans cache when issues detected"
    echo -e "  ${GREEN}Aggressive:${NC}      Always cleans cache (slower but thorough)"
    echo ""
    echo -e "${BLUE}Examples:${NC}"
    echo -e "  ${CYAN}./start-server${NC}           # Fast startup with smart cache management"
    echo -e "  ${CYAN}./start-server --clean${NC}   # Slow but thorough cache clearing"
    echo ""
    exit 0
elif [ -n "$1" ]; then
    echo -e "${RED}❌ Unknown option: $1${NC}"
    echo -e "${BLUE}Use './start-server --help' for usage information${NC}"
    exit 1
fi

echo -e "${BLUE}"
echo "╔════════════════════════════════════════╗"
echo "║        OkBuddy PERSISTENT Server       ║"
echo "║            Background Mode             ║"
echo "║         PERMANENT FIX VERSION          ║"
echo "╚════════════════════════════════════════╝"
echo -e "${NC}"

# PERMANENT FIX: Advanced cache cleaning function
clean_webpack_cache() {
    echo -e "${YELLOW}🧹 Deep cleaning webpack cache and build files...${NC}"
    
    # Remove Next.js cache
    rm -rf .next
    
    # Remove npm cache
    rm -rf node_modules/.cache
    
    # Remove TypeScript cache
    rm -rf .tsbuildinfo
    
    # Remove Jest cache
    rm -rf coverage
    
    # Clear any lingering webpack cache
    if [ -d "node_modules/.cache/webpack" ]; then
        rm -rf node_modules/.cache/webpack
    fi
    
    echo -e "${GREEN}✅ Deep cache cleanup complete${NC}"
}

# ENHANCED: Improved cache issue detection
check_for_cache_issues() {
    local needs_clean=false
    
    # Check for webpack cache artifacts
    if [ -f ".next/cache/webpack/.gitignore" ] || [ -d "node_modules/.cache/webpack" ]; then
        needs_clean=true
    fi
    
    # Check for recent error patterns in logs
    if [ -f "$LOG_FILE" ]; then
        if grep -q "Cannot find module\|Module not found\|Unexpected token\|webpack.*Error\|TypeError.*trim" "$LOG_FILE"; then
            needs_clean=true
        fi
    fi
    
    # Check for corrupted Next.js build
    if [ -d ".next" ] && [ ! -f ".next/BUILD_ID" ]; then
        needs_clean=true
    fi
    
    echo $needs_clean
}

# PERMANENT FIX: Dependency validation
validate_dependencies() {
    echo -e "${BLUE}🔍 Validating dependencies...${NC}"
    
    # Check for critical dependency issues
    if ! npm list --depth=0 >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠️ Dependency issues detected, running npm install...${NC}"
        npm install
    fi
    
    echo -e "${GREEN}✅ Dependencies validated${NC}"
}

# Check if server is already running
if [ -f "$PID_FILE" ]; then
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        if [ "$FORCE_CLEAN" = true ]; then
            echo -e "${YELLOW}🛑 Stopping existing server for cache cleaning...${NC}"
            kill $PID 2>/dev/null || true
            rm -f "$PID_FILE"
            sleep 2
        else
            echo -e "${GREEN}✅ Server already running (PID: $PID)${NC}"
            echo -e "${CYAN}📊 Server URL: http://localhost:$PORT${NC}"
            echo -e "${CYAN}📋 Logs: tail -f $LOG_FILE${NC}"
            echo -e "${CYAN}🛑 Stop: ./stop-server${NC}"
            echo -e "${BLUE}💡 Use './start-server --clean' to force cache clearing${NC}"
            exit 0
        fi
    else
        echo -e "${YELLOW}⚠️ Stale PID file found, cleaning up...${NC}"
        rm -f "$PID_FILE"
    fi
fi

# ENHANCED: Pre-startup cleanup and validation
echo -e "${YELLOW}🧹 Performing pre-startup maintenance...${NC}"

# Smart cache cleaning logic
if [ "$FORCE_CLEAN" = true ]; then
    echo -e "${YELLOW}🧹 Force cleaning requested...${NC}"
    clean_webpack_cache
elif [ "$(check_for_cache_issues)" = true ]; then
    echo -e "${YELLOW}🔧 Cache issues detected, cleaning...${NC}"
    clean_webpack_cache
fi

# Validate dependencies
validate_dependencies

# Kill any existing processes on the port
echo -e "${YELLOW}🧹 Cleaning up existing processes...${NC}"
if lsof -ti:$PORT >/dev/null 2>&1; then
    lsof -ti:$PORT | xargs kill -9 2>/dev/null || true
    sleep 2
fi

echo -e "${GREEN}✅ Port cleanup complete${NC}"

# PERMANENT FIX: Start server with enhanced error handling
echo -e "${BLUE}🚀 Starting persistent background server...${NC}"

# Start the server in background with comprehensive logging
nohup npm run dev > "$LOG_FILE" 2>&1 &
SERVER_PID=$!

# Save PID
echo $SERVER_PID > "$PID_FILE"
echo -e "${GREEN}✅ Server started persistently (PID: $SERVER_PID)${NC}"

# PERMANENT FIX: Enhanced health check with webpack error detection
echo -e "${BLUE}🔍 Performing comprehensive health check...${NC}"

for i in $(seq 1 $HEALTH_CHECK_TIMEOUT); do
    # Check if process is still running
    if ! kill -0 $SERVER_PID 2>/dev/null; then
        echo -e "${RED}❌ Server process died during startup${NC}"
        
        # Check for webpack errors in logs
        if grep -q "Cannot find module" "$LOG_FILE" 2>/dev/null; then
            echo -e "${YELLOW}🔧 Webpack module error detected, applying permanent fix...${NC}"
            clean_webpack_cache
            validate_dependencies
            
            # Retry server start
            nohup npm run dev > "$LOG_FILE" 2>&1 &
            SERVER_PID=$!
            echo $SERVER_PID > "$PID_FILE"
            echo -e "${GREEN}✅ Server restarted with clean cache (PID: $SERVER_PID)${NC}"
            continue
        fi
        
        rm -f "$PID_FILE"
        exit 1
    fi
    
    # Check HTTP response
    if curl -s http://localhost:$PORT >/dev/null 2>&1; then
        echo -e "${GREEN}✅ Server is healthy and responding${NC}"
        break
    fi
    
    if [ $i -eq $HEALTH_CHECK_TIMEOUT ]; then
        echo -e "${RED}❌ Server failed to respond within $HEALTH_CHECK_TIMEOUT seconds${NC}"
        kill $SERVER_PID 2>/dev/null || true
        rm -f "$PID_FILE"
        exit 1
    fi
    
    sleep 1
done

# Success message
echo -e "${GREEN}"
echo "╔════════════════════════════════════════╗"
echo "║           🚀 SERVER RUNNING            ║"
echo "╚════════════════════════════════════════╝"
echo -e "${NC}"

echo -e "${CYAN}📊 URL:      http://localhost:$PORT${NC}"
echo -e "${CYAN}🆔 PID:      $SERVER_PID${NC}"
echo -e "${CYAN}📋 Logs:     tail -f $LOG_FILE${NC}"
echo -e "${CYAN}🛑 Stop:     ./stop-server${NC}"
echo ""
echo -e "${GREEN}✅ Server is running persistently in background!${NC}"
echo -e "${BLUE}💡 The server will continue running even if you close this terminal.${NC}"
echo -e "${BLUE}🔧 Enhanced with permanent webpack error prevention.${NC}" 