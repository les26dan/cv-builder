#!/bin/bash

# OkBuddy Bulletproof Server Startup Script
# This script can be run from ANYWHERE and will automatically find and start the server

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Banner
echo -e "${BLUE}${BOLD}"
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                    🚀 OkBuddy Server Starter 🚀              ║"
echo "║              Bulletproof Edition - Works Anywhere!          ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo -e "${NC}"

# Function to find the OkBuddy project directory automatically
find_project_directory() {
  echo -e "${YELLOW}🔍 Auto-detecting OkBuddy project directory...${NC}"
  
  # Possible project locations (in order of preference)
  local possible_dirs=(
    "/Users/tomnguyen/Documents/Cursor/Projects/OkBuddy"
    "$(pwd)/OkBuddy"
    "$(dirname "$(dirname "$0")")"
    "$(pwd)"
    "$(find /Users -name "OkBuddy" -type d 2>/dev/null | grep -E "Documents|Projects" | head -1)"
  )
  
  # Check each possible directory
  for dir in "${possible_dirs[@]}"; do
    if [ -n "$dir" ] && [ -f "$dir/package.json" ]; then
      # Verify it's actually the OkBuddy project
      if grep -q "okbuddy-unified" "$dir/package.json" 2>/dev/null; then
        echo -e "${GREEN}✅ Found OkBuddy project at: $dir${NC}"
        PROJECT_DIR="$dir"
        return 0
      fi
    fi
  done
  
  echo -e "${RED}❌ Could not find OkBuddy project directory!${NC}"
  echo -e "${YELLOW}Please ensure the project exists at one of these locations:${NC}"
  echo "  - /Users/tomnguyen/Documents/Cursor/Projects/OkBuddy"
  echo "  - Current directory or subdirectory"
  echo ""
  read -p "Enter the full path to OkBuddy project (or press Enter to exit): " manual_path
  
  if [ -n "$manual_path" ] && [ -f "$manual_path/package.json" ]; then
    PROJECT_DIR="$manual_path"
    echo -e "${GREEN}✅ Using manually specified directory: $PROJECT_DIR${NC}"
    return 0
  fi
  
  echo -e "${RED}❌ Invalid or missing project directory. Exiting.${NC}"
  exit 1
}

# Function to ensure we're in the correct directory
ensure_correct_directory() {
  echo -e "${YELLOW}📂 Navigating to project directory...${NC}"
  
  cd "$PROJECT_DIR" || {
    echo -e "${RED}❌ Failed to navigate to $PROJECT_DIR${NC}"
    exit 1
  }
  
  echo -e "${GREEN}✅ Now in: $(pwd)${NC}"
  echo ""
}

# Function to check if port is in use
check_port() {
  local port=$1
  if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1 ; then
    return 0
  else
    return 1
  fi
}

# Function to kill existing processes aggressively
cleanup_existing_servers() {
  echo -e "${YELLOW}🧹 Aggressively cleaning up all existing servers...${NC}"
  
  # Kill Next.js processes
  pkill -f "next dev" 2>/dev/null || true
  pkill -f "next-server" 2>/dev/null || true
  pkill -f "okbuddy" 2>/dev/null || true
  
  # Kill Node processes that might be holding port 3000
  if check_port 3000; then
    echo -e "${YELLOW}⚠️ Port 3000 is occupied. Force-killing processes...${NC}"
    lsof -ti:3000 | xargs kill -9 2>/dev/null || true
    sleep 2
  fi
  
  # Check ports 3001-3005 as backup
  for port in {3001..3005}; do
    if check_port $port; then
      echo -e "${YELLOW}⚠️ Cleaning up port $port...${NC}"
      lsof -ti:$port | xargs kill -9 2>/dev/null || true
    fi
  done
  
  # Wait for cleanup
  sleep 3
  
  echo -e "${GREEN}✅ All processes cleaned up${NC}"
  echo ""
}

# Function to check and install dependencies
check_dependencies() {
  echo -e "${YELLOW}📦 Checking dependencies...${NC}"
  
  if [ ! -f "package.json" ]; then
    echo -e "${RED}❌ package.json not found in current directory!${NC}"
    echo "Current directory: $(pwd)"
    exit 1
  fi
  
  if [ ! -d "node_modules" ] || [ ! -f "node_modules/.package-lock.json" ]; then
    echo -e "${YELLOW}⚠️ Dependencies missing or outdated. Installing...${NC}"
    npm install --silent || {
      echo -e "${RED}❌ Failed to install dependencies${NC}"
      exit 1
    }
  fi
  
  echo -e "${GREEN}✅ Dependencies ready${NC}"
  echo ""
}

# Function to clear cache aggressively
clear_cache() {
  echo -e "${YELLOW}🗑️ Clearing all caches...${NC}"
  
  # Remove Next.js cache
  rm -rf .next 2>/dev/null || true
  rm -rf node_modules/.cache 2>/dev/null || true
  rm -rf .swc 2>/dev/null || true
  
  # Clear npm cache if needed
  npm cache clean --force 2>/dev/null || true
  
  echo -e "${GREEN}✅ All caches cleared${NC}"
  echo ""
}

# Function to verify server is actually working
wait_for_server() {
  local port=3000
  local max_attempts=60  # Increased timeout
  local attempt=1
  
  echo -e "${YELLOW}⏳ Waiting for server to start (up to 60 seconds)...${NC}"
  
  while [ $attempt -le $max_attempts ]; do
    # Check if process is still running
    if ! pgrep -f "next dev" > /dev/null; then
      echo -e "${RED}❌ Server process died unexpectedly${NC}"
      return 1
    fi
    
    # Test if server responds
    local status=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$port 2>/dev/null || echo "000")
    
    if [[ "$status" =~ ^(200|302|308|404)$ ]]; then
      echo -e "${GREEN}✅ Server is responding (Status: $status)${NC}"
      return 0
    fi
    
    # Progress indicator
    if [ $((attempt % 10)) -eq 0 ]; then
      echo -e "${CYAN}   Attempt $attempt/$max_attempts - server starting...${NC}"
    elif [ $((attempt % 5)) -eq 0 ]; then
      echo -n "."
    fi
    
    sleep 1
    ((attempt++))
  done
  
  echo -e "${RED}❌ Server failed to start within 60 seconds${NC}"
  return 1
}

# Function to run comprehensive health check
run_health_check() {
  echo -e "${YELLOW}🏥 Running comprehensive health checks...${NC}"
  
  local pages=("/" "/login" "/register" "/cv-workspace" "/terms-of-service")
  local all_passed=true
  
  for page in "${pages[@]}"; do
    local status=$(curl -s -o /dev/null -w "%{http_code}" "http://localhost:3000$page" 2>/dev/null || echo "000")
    
    case $status in
      200|302|308) 
        echo -e "   ✅ $page (Status: $status)"
        ;;
      404)
        echo -e "   ⚠️ $page (Status: $status - Page exists but requires auth)"
        ;;
      *)
        echo -e "   ❌ $page (Status: $status)"
        all_passed=false
        ;;
    esac
  done
  
  if [ "$all_passed" = true ]; then
    echo -e "${GREEN}✅ All health checks passed!${NC}"
  else
    echo -e "${YELLOW}⚠️ Some pages returned unexpected status codes (this might be normal for auth-protected pages)${NC}"
  fi
  
  echo ""
}

# Function to show comprehensive server info
show_server_info() {
  local current_time=$(date '+%Y-%m-%d %H:%M:%S')
  
  echo -e "${GREEN}${BOLD}"
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║                🎉 SERVER STARTED SUCCESSFULLY! 🎉           ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo -e "${NC}"
  
  echo -e "${BLUE}📍 Server Information:${NC}"
  echo -e "   🌐 URL:           http://localhost:3000"
  echo -e "   📁 Directory:     $PROJECT_DIR"
  echo -e "   ⏰ Started:       $current_time"
  echo -e "   🔧 Node Version:  $(node --version 2>/dev/null || echo 'Unknown')"
  echo -e "   📦 NPM Version:   $(npm --version 2>/dev/null || echo 'Unknown')"
  echo ""
  
  echo -e "${CYAN}🔗 Quick Access Links:${NC}"
  echo -e "   🏠 Landing Page:      http://localhost:3000"
  echo -e "   🔐 Login:             http://localhost:3000/login"
  echo -e "   📝 Register:          http://localhost:3000/register"
  echo -e "   💼 CV Workspace:      http://localhost:3000/cv-workspace"
  echo -e "   📄 CV Upload:         http://localhost:3000/cv-upload"
  echo -e "   ✏️ CV Editor (New):   http://localhost:3000/cv-guided-editing/test?source=new"
  echo -e "   👑 Admin Dashboard:   http://localhost:3000/admin"
  echo ""
  
  echo -e "${YELLOW}⚡ Quick Commands (run from ANY directory):${NC}"
  echo -e "   📊 Check Status:      curl -I http://localhost:3000"
  echo -e "   🔄 Restart Server:    $PROJECT_DIR/start-server"
  echo -e "   🛑 Stop Server:       pkill -f 'next dev'"
  echo ""
  
  echo -e "${GREEN}${BOLD}✅ Everything is ready! The server is running smoothly.${NC}"
  echo -e "${YELLOW}Press Ctrl+C to stop the server${NC}"
  echo ""
}

# Function to start server with error handling
start_server() {
  echo -e "${BLUE}🚀 Starting Next.js development server...${NC}"
  echo ""
  
  # Start server in background and capture PID
  npm run dev &
  local server_pid=$!
  
  # Give the server a moment to initialize
  sleep 2
  
  # Check if the process is still running
  if ! kill -0 $server_pid 2>/dev/null; then
    echo -e "${RED}❌ Server process failed to start${NC}"
    return 1
  fi
  
  return 0
}

# Handle script interruption gracefully
trap 'echo -e "\n${YELLOW}🛑 Stopping server gracefully...${NC}"; pkill -f "next dev" 2>/dev/null || true; echo -e "${GREEN}✅ Server stopped. Goodbye!${NC}"; exit 0' INT TERM

# Main execution function
main() {
  # Step 1: Find the project directory
  find_project_directory
  
  # Step 2: Navigate to the correct directory
  ensure_correct_directory
  
  # Step 3: Clean up existing servers
  cleanup_existing_servers
  
  # Step 4: Check dependencies
  check_dependencies
  
  # Step 5: Clear cache
  clear_cache
  
  # Step 6: Start the server
  if start_server; then
    echo -e "${GREEN}✅ Server process started successfully${NC}"
  else
    echo -e "${RED}❌ Failed to start server process${NC}"
    exit 1
  fi
  
  # Step 7: Wait for server to be ready
  if wait_for_server; then
    echo -e "${GREEN}✅ Server is ready and responding${NC}"
  else
    echo -e "${RED}❌ Server failed to become ready${NC}"
    echo -e "${YELLOW}Attempting to show error logs...${NC}"
    pkill -f "next dev" 2>/dev/null || true
    exit 1
  fi
  
  # Step 8: Run health checks
  run_health_check
  
  # Step 9: Show server information
  show_server_info
  
  # Step 10: Keep the script running (wait for Ctrl+C)
  echo -e "${CYAN}Monitoring server... (Press Ctrl+C to stop)${NC}"
  while true; do
    if ! pgrep -f "next dev" > /dev/null; then
      echo -e "${RED}⚠️ Server process stopped unexpectedly!${NC}"
      break
    fi
    sleep 5
  done
}

# Emergency recovery function
emergency_recovery() {
  echo -e "${RED}🚨 EMERGENCY RECOVERY MODE 🚨${NC}"
  echo -e "${YELLOW}Attempting to recover from failed startup...${NC}"
  
  # Kill everything aggressively
  pkill -9 -f "next" 2>/dev/null || true
  pkill -9 -f "node" 2>/dev/null || true
  
  # Clear everything
  rm -rf .next node_modules/.cache .swc 2>/dev/null || true
  
  # Reinstall dependencies
  echo -e "${YELLOW}Reinstalling dependencies...${NC}"
  npm install --force
  
  # Try to start again
  echo -e "${YELLOW}Attempting restart...${NC}"
  npm run dev
}

# Check if we're in recovery mode
if [ "$1" = "--recovery" ]; then
  find_project_directory
  ensure_correct_directory
  emergency_recovery
  exit $?
fi

# Run main function
main

# If we get here, something went wrong
echo -e "${RED}❌ Script ended unexpectedly${NC}"
echo -e "${YELLOW}💡 Try running with recovery mode: $0 --recovery${NC}"
exit 1 