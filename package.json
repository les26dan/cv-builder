{
  "name": "okbuddy-unified",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "restart": "pkill -f 'next dev' || true && sleep 2 && npm run dev",
    "clean": "rm -rf .next && npm run dev",
    "server": "./start-server",
    "server:stop": "./stop-server",
    "server:status": "./check-server",
    "server:logs": "tail -f server-persistent.log",
    "stop": "pkill -f 'next dev' || true",
    "status": "curl -s http://localhost:3000 >/dev/null && echo 'Server running ✅' || echo 'Server not running ❌'",
    "check": "curl -s -o /dev/null -w 'Landing: %{http_code}' http://localhost:3000 && echo ' | Login: '$(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/login) && echo ' | Workspace: '$(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/cv-workspace)",
    "test:workspace": "./scripts/test-cv-workspace.sh",
    "validate-pages": "./scripts/validate-pages.sh",
    "db:test": "node scripts/test-supabase-connection.js",
    "db:deploy": "./scripts/deploy-database.sh",
    "deep-clean": "rm -rf .next node_modules/.cache package-lock.json && npm install && npm run build",
    "fix-webpack": "rm -rf .next node_modules/.cache && npm run dev",
    "reset": "pkill -f 'next dev' || true && rm -rf .next node_modules/.cache && npm install",
    "audit-fix": "npm audit fix --force",
    "permanent-fix": "./scripts/permanent-fix.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.50.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/file-saver": "^2.0.5",
    "@types/formidable": "^3.4.5",
    "@types/nodemailer": "^6.4.17",
    "@vercel/blob": "^1.1.1",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "docx": "^8.2.2",
    "file-saver": "^2.0.5",
    "formidable": "^3.5.4",
    "html2canvas": "^1.4.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.525.0",
    "mammoth": "^1.9.1",
    "next": "15.1.8",
    "nodemailer": "^7.0.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.1"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/eslintrc": "^3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-jest": "^29.7.0",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.8",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
